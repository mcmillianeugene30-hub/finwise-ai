# ─────────────────────────────────────────────────
#  FinWise AI — Environment Variable Template
#  Copy this file to .env and fill in your values.
#  NEVER commit your real .env file to source control.
# ─────────────────────────────────────────────────

# ── Server ───────────────────────────────────────
# Port the Express server will listen on
PORT=5000

# Node environment: development | production | test
NODE_ENV=development

# ── Database ─────────────────────────────────────
# MongoDB connection string
# Local:  mongodb://localhost:27017/finwise
# Atlas:  mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/finwise
MONGO_URI=mongodb://localhost:27017/finwise

# ── Authentication ───────────────────────────────
# Secret key used to sign JWTs — use a long, random string in production
# Generate one: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_a_long_random_secret_string

# JWT expiry duration (e.g. 7d, 24h, 60m)
JWT_EXPIRES_IN=7d

# ── OpenAI ───────────────────────────────────────
# Your OpenAI API key — get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# GPT model to use (gpt-4o, gpt-4-turbo, gpt-3.5-turbo)
OPENAI_MODEL=gpt-4o

# Max tokens per AI response
OPENAI_MAX_TOKENS=512

# ── CORS ─────────────────────────────────────────
# Allowed origin for cross-origin requests (React dev server)
CLIENT_ORIGIN=http://localhost:3000
